# Copy to .env (or export these) to customize the stack.
#
# Shared auth secret used by the users service (mints JWTs) and the ledger
# service (validates them). Must match across both.
TOKEN_SECRET=demo-shared-secret
FRONTEND_SECRET=demo-frontend-secret

# Published host ports. Defaults match the canonical 8080-8083 layout.
# Container ports are fixed; only these published host ports change.
USERS_PORT=8081
LEDGER_PORT=8082
STATEMENTS_PORT=8083
FRONTEND_PORT=8080

# --- Running a second, parallel stack (PORT_OFFSET convention) ---
# Compose cannot do arithmetic, so apply the offset to each port and give the
# stack its own project name so containers/volumes/networks do not clash:
#
#   COMPOSE_PROJECT_NAME=gemini-bank-2
#   USERS_PORT=9081
#   LEDGER_PORT=9082
#   STATEMENTS_PORT=9083
#   FRONTEND_PORT=9080
#
# i.e. PORT_OFFSET=+1000 over the defaults. The second stack is then reachable
# at http://localhost:9080. Useful for running two checkouts side by side.
COMPOSE_PROJECT_NAME=gemini-bank
